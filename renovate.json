{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "schedule": ["every weekend"],
  "helm-values": {
    "managerFilePatterns": ["/argocd/apps/.+/values\\.yaml$/"]
  },
  "helmv3": {
    "managerFilePatterns": ["/argocd/apps/.+/Chart\\.yaml$/"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "minor and patch updates"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.github/workflows/.+\\.yaml$/",
        "/data/versions\\.yaml$/"
      ],
      "matchStrings": [
        "# renovate: depName=(?<depName>[^\\s]+) datasource=(?<datasource>[^\\s]+)\\n\\w+: \"(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "semver"
    }
  ]
}
