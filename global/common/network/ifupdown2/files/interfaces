# network interface settings; autogenerated
# Please do NOT modify this file directly, unless you know what
# you're doing.
#
# If you want to manage parts of the network configuration manually,
# please utilize the 'source' or 'source-directory' directives to do
# so.
# PVE will preserve these directives, but will NOT read its network
# configuration from sourced files, so do not attempt to move any of
# the PVE managed interfaces into external files!

auto lo
iface lo inet loopback

iface nic1 inet manual
#SW PORT 2 - LAN

auto nic0
iface nic0 inet manual
#SW PORT 1 - WAN

iface wlp195s0 inet manual

auto vmbr1
iface vmbr1 inet manual
	bridge-ports nic1
	bridge-stp off
	bridge-fd 0
	bridge-vlan-aware yes
	bridge-vids 2-4094

# If VLAN/LAN is broken, you can temporarily enable this
# to access Proxmox via WAN network (Freebox LAN 192.168.0.0/24)
# Disable the vmbr0 & vmbr1.10 blocks and enable this one

#auto vmbr0
#iface vmbr0 inet static
#        address 192.168.0.251/24
#        gateway 192.168.0.254
#        bridge-ports nic0

auto vmbr0
iface vmbr0 inet manual
	bridge-ports nic0
	bridge-stp off
	bridge-fd 0

auto vmbr1.10
iface vmbr1.10 inet static
	address {{ ip }}/24
	gateway {{ gateway }}
